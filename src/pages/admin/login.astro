---
import { validateAdminSession } from '../../utils/adminAuth';

export const prerender = false;

const token = Astro.cookies.get('admin_session')?.value;
if (await validateAdminSession(token)) {
  return Astro.redirect('/admin');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — aria</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Ubuntu+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Ubuntu Mono', 'DejaVu Sans Mono', monospace;
      background: linear-gradient(165deg, #0a0e17 0%, #0f1419 22%, #0d1117 45%, #0a0e17 70%, #050810 100%);
      color: #e2e8f0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      overflow: hidden;
    }

    /* Mesh overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse 80% 50% at 20% 20%, rgba(59,130,246,0.12) 0%, transparent 50%),
        radial-gradient(ellipse 60% 80% at 85% 60%, rgba(99,102,241,0.08) 0%, transparent 50%),
        radial-gradient(ellipse 50% 40% at 50% 90%, rgba(6,182,212,0.06) 0%, transparent 45%);
      z-index: 0;
    }

    /* Dot grid */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
      background-size: 64px 64px;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 70%);
      z-index: 0;
    }

    .card {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 380px;
      background: rgba(13,17,23,0.9);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px;
      padding: 2.25rem 2rem;
      box-shadow:
        0 24px 64px rgba(0,0,0,0.6),
        0 0 0 1px rgba(59,130,246,0.05),
        inset 0 1px 0 rgba(255,255,255,0.04);
      animation: fadeUp 0.4s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }

    .brand-icon {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      background: rgba(59,130,246,0.1);
      border: 1px solid rgba(59,130,246,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #60a5fa;
      box-shadow: 0 0 16px rgba(59,130,246,0.15);
    }

    .brand-name {
      font-size: 1rem;
      font-weight: 700;
      color: #f1f5f9;
      letter-spacing: -0.01em;
    }

    .brand-sub {
      font-size: 0.65rem;
      color: #64748b;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    /* Divider */
    .divider {
      height: 1px;
      background: rgba(255,255,255,0.06);
      margin-bottom: 1.75rem;
    }

    h1 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #f8fafc;
      margin-bottom: 0.3rem;
    }

    .subtitle {
      font-size: 0.75rem;
      color: #64748b;
      margin-bottom: 1.75rem;
      line-height: 1.5;
    }

    label {
      display: block;
      font-size: 0.65rem;
      color: #64748b;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .input-wrap {
      position: relative;
      margin-bottom: 1.25rem;
    }

    .input-icon {
      position: absolute;
      left: 0.875rem;
      top: 50%;
      transform: translateY(-50%);
      color: #334155;
      pointer-events: none;
    }

    input[type="password"] {
      width: 100%;
      padding: 0.75rem 1rem 0.75rem 2.5rem;
      background: rgba(22,27,34,0.8);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 11px;
      color: #e2e8f0;
      font-family: 'Ubuntu Mono', monospace;
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      letter-spacing: 0.1em;
    }

    input[type="password"]::placeholder {
      color: #1e293b;
      letter-spacing: 0;
    }

    input[type="password"]:focus {
      border-color: rgba(59,130,246,0.4);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
    }

    .btn-submit {
      width: 100%;
      padding: 0.8rem;
      background: linear-gradient(135deg, #3b82f6, #6366f1);
      border: none;
      border-radius: 11px;
      color: #fff;
      font-family: 'Ubuntu Mono', monospace;
      font-size: 0.875rem;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: 0.02em;
      position: relative;
      overflow: hidden;
      transition: opacity 0.2s, transform 0.15s;
      box-shadow: 0 4px 16px rgba(59,130,246,0.25);
    }

    .btn-submit::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
      opacity: 0;
      transition: opacity 0.2s;
    }

    .btn-submit:hover::before { opacity: 1; }
    .btn-submit:active { transform: scale(0.99); }
    .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .error-box {
      display: none;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1rem;
      padding: 0.625rem 0.875rem;
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 9px;
      color: #f87171;
      font-size: 0.75rem;
      line-height: 1.4;
    }

    .error-box.show { display: flex; }

    .footer-note {
      margin-top: 1.5rem;
      text-align: center;
      font-size: 0.65rem;
      color: #1e293b;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="brand">
      <div class="brand-icon">
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <div>
        <div class="brand-name">aria admin</div>
        <div class="brand-sub">moderation console</div>
      </div>
    </div>

    <div class="divider"></div>

    <h1>Sign in</h1>
    <p class="subtitle">Admin access only. Enter your password to continue.</p>

    <form id="login-form" autocomplete="off">
      <label for="password">Admin password</label>
      <div class="input-wrap">
        <span class="input-icon">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </span>
        <input
          id="password"
          type="password"
          placeholder="Enter password"
          autocomplete="current-password"
          required
        />
      </div>

      <button type="submit" id="submit-btn" class="btn-submit">Sign in</button>

      <div id="error-box" class="error-box">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span id="error-text"></span>
      </div>
    </form>

    <p class="footer-note">Session expires after 24 hours.</p>
  </div>

  <script>
    document.getElementById('login-form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const btn      = document.getElementById('submit-btn') as HTMLButtonElement;
      const errorBox = document.getElementById('error-box') as HTMLElement;
      const errorTxt = document.getElementById('error-text') as HTMLElement;

      btn.disabled = true;
      btn.textContent = 'Signing in…';
      errorBox.classList.remove('show');

      try {
        const res  = await fetch('/api/admin/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password }),
        });
        const data = await res.json();

        if (res.ok) {
          window.location.href = '/admin';
        } else {
          errorTxt.textContent = data.error || 'Login failed. Check your password.';
          errorBox.classList.add('show');
        }
      } catch {
        errorTxt.textContent = 'Network error — please try again.';
        errorBox.classList.add('show');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Sign in';
      }
    });
  </script>
</body>
</html>
