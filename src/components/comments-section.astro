---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<section class="w-full max-w-2xl mx-auto mt-16 mb-8 px-0">
  <div class="border-t border-neutral-200 dark:border-neutral-800 pt-10">

    <div class="flex items-center gap-2 mb-8">
      <h2 class="text-base font-bold text-neutral-900 dark:text-neutral-100 uppercase tracking-widest">
        Comments
      </h2>
      <span id="comment-count" class="text-xs text-neutral-400 dark:text-neutral-600 hidden">
        (<span id="comment-count-num">0</span>)
      </span>
    </div>

    <!-- Comment Form -->
    <form id="comment-form" class="mb-10">
      <textarea
        id="comment-input"
        placeholder="Share your thoughts... (posted anonymously)"
        rows="4"
        maxlength="1000"
        class="w-full px-4 py-3 rounded-xl bg-white dark:bg-neutral-900/60 border border-neutral-200 dark:border-neutral-700/60 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-600 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-blue-500/40 focus:border-blue-400 dark:focus:border-blue-500"
      ></textarea>
      <div class="flex items-center justify-between mt-3">
        <p class="text-xs text-neutral-400 dark:text-neutral-600">
          Anonymous — a random username &amp; avatar are assigned automatically.
        </p>
        <button
          type="submit"
          id="submit-btn"
          class="px-5 py-2 rounded-lg bg-blue-500 hover:bg-blue-600 active:bg-blue-700 text-white text-sm font-semibold disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Post
        </button>
      </div>
      <div id="form-message" class="hidden mt-3 text-xs rounded-lg px-3 py-2"></div>
    </form>

    <!-- Comments List -->
    <div id="comments-list" class="space-y-3">
      <p id="comments-loading" class="text-sm text-neutral-400 dark:text-neutral-600">Loading comments...</p>
    </div>
  </div>
</section>

<script define:vars={{ slug }}>
  const AVATAR_BASE = 'https://api.dicebear.com/9.x/shapes/svg';

  function avatarUrl(seed) {
    return `${AVATAR_BASE}?seed=${encodeURIComponent(seed)}&size=36&backgroundType=gradientLinear`;
  }

  function relativeTime(ts) {
    const diff = Math.floor((Date.now() - ts) / 1000);
    if (diff < 60) return 'just now';
    if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
    if (diff < 604800) return `${Math.floor(diff / 86400)}d ago`;
    return new Date(ts).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function escapeHtml(str) {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function buildCommentEl(comment) {
    const el = document.createElement('div');
    el.dataset.commentId = comment.id;
    el.className = 'flex gap-3 p-4 rounded-xl bg-neutral-50 dark:bg-neutral-900/40 border border-neutral-100 dark:border-neutral-800/60';

    // Avatar — falls back to a coloured initial on load error
    const img = document.createElement('img');
    img.src = avatarUrl(comment.avatarSeed);
    img.alt = comment.username;
    img.width = 36;
    img.height = 36;
    img.className = 'w-9 h-9 rounded-full flex-shrink-0 bg-neutral-200 dark:bg-neutral-800';
    img.addEventListener('error', () => {
      const fallback = document.createElement('span');
      fallback.className = 'w-9 h-9 rounded-full flex-shrink-0 bg-blue-500/20 text-blue-600 flex items-center justify-center text-sm font-bold';
      fallback.textContent = comment.username.charAt(0).toUpperCase();
      img.replaceWith(fallback);
    });

    const body = document.createElement('div');
    body.className = 'flex-1 min-w-0';
    body.innerHTML = `
      <div class="flex flex-wrap items-center gap-x-2 mb-1">
        <span class="text-sm font-semibold text-neutral-800 dark:text-neutral-200">${escapeHtml(comment.username)}</span>
        <span class="text-xs text-neutral-400 dark:text-neutral-600">${relativeTime(comment.timestamp)}</span>
      </div>
      <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed whitespace-pre-wrap break-words">${escapeHtml(comment.content)}</p>
    `;

    el.appendChild(img);
    el.appendChild(body);
    return el;
  }

  function updateCount(n) {
    const countEl = document.getElementById('comment-count');
    const numEl = document.getElementById('comment-count-num');
    if (n > 0) {
      numEl.textContent = n;
      countEl.classList.remove('hidden');
    }
  }

  async function loadComments() {
    const list = document.getElementById('comments-list');
    try {
      const res = await fetch(`/api/comments?slug=${encodeURIComponent(slug)}`);
      const data = await res.json();
      list.innerHTML = '';
      const comments = data.comments || [];
      updateCount(comments.length);
      if (comments.length === 0) {
        list.innerHTML = '<p class="text-sm text-neutral-400 dark:text-neutral-600">No comments yet — be the first to leave one.</p>';
        return;
      }
      for (const c of comments) {
        list.appendChild(buildCommentEl(c));
      }
    } catch {
      list.innerHTML = '<p class="text-sm text-neutral-400 dark:text-neutral-600">Could not load comments.</p>';
    }
  }

  function showMessage(text, type) {
    const el = document.getElementById('form-message');
    el.textContent = text;
    el.className = `mt-3 text-xs rounded-lg px-3 py-2 ${
      type === 'error'
        ? 'bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800'
        : 'bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-green-400 border border-green-200 dark:border-green-800'
    }`;
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 5000);
  }

  document.getElementById('comment-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('comment-input');
    const btn = document.getElementById('submit-btn');
    const content = input.value.trim();

    if (content.length < 3) {
      showMessage('Comment must be at least 3 characters.', 'error');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Posting...';

    try {
      const res = await fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, content }),
      });
      const data = await res.json();

      if (!res.ok) {
        showMessage(data.error || 'Failed to post comment.', 'error');
        return;
      }

      input.value = '';
      showMessage('Comment posted!', 'success');

      // Append new comment to list
      const list = document.getElementById('comments-list');
      const empty = list.querySelector('p');
      if (empty) list.innerHTML = '';
      list.appendChild(buildCommentEl(data.comment));

      // Update count
      const numEl = document.getElementById('comment-count-num');
      const countEl = document.getElementById('comment-count');
      const newCount = (parseInt(numEl.textContent) || 0) + 1;
      numEl.textContent = newCount;
      countEl.classList.remove('hidden');
    } catch {
      showMessage('Failed to post comment. Please try again.', 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Post';
    }
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadComments);
  } else {
    loadComments();
  }
</script>
