---
// Renders a single toggle button; JS will switch icon/label based on current theme
---

<button
  type="button"
  aria-label="Toggle dark mode"
  class="theme-toggle flex items-center justify-center w-10 h-10 rounded-xl border border-neutral-300/60 dark:border-white/10 bg-white/10 dark:bg-white/5 hover:bg-neutral-200/80 dark:hover:bg-white/10 text-neutral-600 dark:text-neutral-300 hover:text-neutral-900 dark:hover:text-white transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:ring-offset-2 focus:ring-offset-transparent"
>
  <!-- Sun: visible in dark mode (click to switch to light) -->
  <span id="theme-icon-dark" class="theme-icon hidden dark:block" aria-hidden="true">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
  </span>
  <!-- Moon: visible in light mode (click to switch to dark) -->
  <span id="theme-icon-light" class="theme-icon block dark:hidden" aria-hidden="true">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
    </svg>
  </span>
</button>
